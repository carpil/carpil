# Token con acceso a https://github.com/carpil/app (GitHub Packages)
# Genera uno en: GitHub → Settings → Developer settings → Personal access tokens
# Scopes requeridos: read:packages
NPM_TOKEN_GOOGLE_SIGN_IN=

# Token de Infisical para jalar secrets de dev/preview/production
# Project Access Control → Service Tokens
INFISICAL_TOKEN=
