rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public read — passengers browse rides without logging in.
    // Writes (join/leave/soft-delete) are gated to authenticated users with ownership / passenger checks.
    match /rides/{rideId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.creator == request.auth.uid;
      allow update: if request.auth != null && (
        request.resource.data.passengers == resource.data.passengers + [request.auth.uid] ||
        request.resource.data.passengers == resource.data.passengers - [request.auth.uid] ||
        (
          request.auth.uid == resource.data.creator &&
          request.resource.data.deletedAt == request.time
        )
      );
    }

    // CARPIL-281 (M9.1-A): require authentication for /users reads to prevent
    // unauth Web SDK dumping of user PII (phoneNumber, pushToken, etc.).
    // Broader tightening to (auth.uid == uid) + redacted server endpoints is M9.2-B.
    match /users/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == uid;
    }

    match /ride_requests/{rideId} {
      allow read:   if true;
      allow create: if request.auth != null;
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.owner.id == request.auth.uid;

      match /messages/{messageId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Driver applications: each user owns their own application(s).
    // Status updates (approve/reject) go through the API (Admin SDK bypasses rules).
    match /driver_applications/{applicationId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null
                          && resource.data.userId == request.auth.uid;
    }

    // Explicit safety net — Firestore defaults to deny, but this makes it audit-friendly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
