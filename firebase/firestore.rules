rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public read — passengers browse available rides without logging in.
    // All writes (create, update, soft-delete) go through the API (Admin SDK bypasses rules).
    match /rides/{rideId} {
      allow read: if true;
      allow write: if false;
    }

    // Public read — driver profile info is shown to passengers.
    // Users create and update their own document (bootstrap state sync from the app).
    match /users/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Driver applications: each user owns their own application(s).
    // Status updates (approve/reject) go through the API.
    match /driver_applications/{applicationId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null
                          && resource.data.userId == request.auth.uid;
    }

    // chats, messages, ride-requests, ratings, payments, vehicles, notifications —
    // all managed exclusively by the API (Admin SDK). No direct client access needed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
