rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and update their own document.
    // The app subscribes to this doc for bootstrap state and writes back
    // fields like currentRideId, inRide, pendingReviewRideIds via setDoc merge.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rides are public to authenticated users (passengers browse available rides).
    // All writes go through the API (Admin SDK bypasses these rules).
    match /rides/{rideId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Driver applications: each user owns their own application(s).
    // Status updates (approve/reject) go through the API.
    match /driver_applications/{applicationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // chats, messages, ride-requests, ratings, payments, vehicles, notifications —
    // all managed exclusively by the API (Admin SDK). No direct client access needed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
